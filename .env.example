# Copy to .env and fill in. .env is gitignored.

# ---- App ----
STOCKSCAN_ENV=dev                          # dev | prod
STOCKSCAN_LOG_LEVEL=INFO
STOCKSCAN_TIMEZONE=America/New_York

# ---- Database ----
# For Docker Compose default: postgres on localhost:5432
DATABASE_URL=postgresql+psycopg://stockscan:CHANGE_ME@127.0.0.1:5432/stockscan

# ---- Data provider (EODHD) ----
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api

# ---- Broker (E*TRADE) ----
# Phase 4. Leave empty for Suggestion Mode.
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_USE_SANDBOX=true

# ---- Notifications ----
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
POSTMARK_TOKEN=
DISCORD_WEBHOOK_URL=

# ---- Risk caps (overrides defaults from DESIGN §4.7) ----
STOCKSCAN_DEFAULT_RISK_PCT=0.01
STOCKSCAN_MAX_POSITIONS=15
STOCKSCAN_MAX_SECTOR_PCT=0.25
STOCKSCAN_MAX_POSITION_PCT=0.08
STOCKSCAN_MAX_ADV_PCT=0.05
STOCKSCAN_DRAWDOWN_CIRCUIT_BREAKER=0.15
