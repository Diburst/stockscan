# Copy to .env and fill in. .env is gitignored.

# ---- App ----
STOCKSCAN_ENV=dev                          # dev | prod
STOCKSCAN_LOG_LEVEL=INFO
STOCKSCAN_TIMEZONE=America/New_York

# ---- Logging ----
# Rotating file logs land in <repo>/logs by default (logs/ in the container).
# STOCKSCAN_LOG_DIR=
# STOCKSCAN_LOG_TO_FILE=true
# Web requests slower than this (ms) log at WARNING:
# STOCKSCAN_SLOW_REQUEST_MS=750

# ---- Database ----
# Bare-metal / infra-compose dev path: postgres on localhost:5432.
# (The full-stack docker-compose.yml overrides DATABASE_URL per service —
# it builds the URL from STOCKSCAN_DB_PASSWORD below and host `db`.)
DATABASE_URL=postgresql+psycopg://stockscan:CHANGE_ME@127.0.0.1:5432/stockscan
# Required by docker-compose.yml (full-stack deploy). Single source of
# truth for the DB password on that path:
STOCKSCAN_DB_PASSWORD=CHANGE_ME

# ---- Data provider (EODHD) ----
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api

# ---- Macro data (FRED — HY OAS credit-stress component of the regime) ----
FRED_API_KEY=

# ---- Broker (E*TRADE) ----
# Phase 4. Leave empty for Suggestion Mode.
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_USE_SANDBOX=true

# ---- Notifications ----
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
POSTMARK_TOKEN=
DISCORD_WEBHOOK_URL=

# ---- Risk caps (overrides defaults from DESIGN §4.7) ----
STOCKSCAN_DEFAULT_RISK_PCT=0.01
STOCKSCAN_MAX_POSITIONS=15
STOCKSCAN_MAX_SECTOR_PCT=0.25
STOCKSCAN_MAX_POSITION_PCT=0.08
STOCKSCAN_MAX_ADV_PCT=0.05
STOCKSCAN_DRAWDOWN_CIRCUIT_BREAKER=0.15
